#!/bin/bash
# ============================================================
# DS-Tracks Kiosk Mode X Session Configuration
# ============================================================
# This file is installed to /home/pi/.xinitrc
# It configures the X session for kiosk mode operation
# ============================================================

# Hide cursor after 0.5 seconds of inactivity
unclutter -idle 0.5 -root &

# Start window manager in background
openbox-session &

# Wait for window manager to start
sleep 1


# Wait for Apache to be ready (localhost only, no network needed)
for i in {1..10}; do
    if curl -s -o /dev/null http://localhost/login.php 2>/dev/null; then
        break
    fi
    sleep 1
done

# Get configuration for cursor hiding
HIDE_CURSOR="true"
if [ -f /boot/firmware/ds-config.txt ]; then
    HIDE_CURSOR=$(grep "^HIDE_CURSOR=" /boot/firmware/ds-config.txt | cut -d'=' -f2 || echo "true")
elif [ -f /boot/ds-config.txt ]; then
    HIDE_CURSOR=$(grep "^HIDE_CURSOR=" /boot/ds-config.txt | cut -d'=' -f2 || echo "true")
fi

# Build Chromium flags
CHROMIUM_FLAGS=(
    --kiosk
    --noerrdialogs
    --disable-infobars
    --disable-session-crashed-bubble
    --disable-restore-session-state
    --disable-translate
    --no-first-run
    --start-fullscreen
    --autoplay-policy=no-user-gesture-required
    --disable-features=TranslateUI
    --disable-pinch
    --overscroll-history-navigation=0
    --check-for-update-interval=604800
    --disable-component-update
)

# Add cursor flag if hiding cursor
if [ "$HIDE_CURSOR" = "true" ]; then
    CHROMIUM_FLAGS+=(--cursor=none)
fi

# Screen blanking and DPMS power saving (5 min idle)
xset s 300
xset s blank
xset +dpms
xset dpms 300 300 300

# Dismiss Plymouth splash screen
sudo plymouth quit --retain-splash 2>/dev/null || true
sudo plymouth quit 2>/dev/null || true


# Launch Chromium in kiosk mode
# Loop to restart if it crashes
while true; do
    chromium "${CHROMIUM_FLAGS[@]}" http://localhost/login.php

    # If Chromium exits, wait a moment then restart
    echo "Chromium exited, restarting in 3 seconds..."
    sleep 3
done
