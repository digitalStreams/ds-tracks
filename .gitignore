# DS-Tracks - Git Ignore File

# Log files (keep .htaccess for security)
logs/*.log
!logs/.htaccess

# Music files (user uploaded content)
music/*
!music/.gitkeep

# System files
.DS_Store
Thumbs.db

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Temporary files
*.tmp
*.bak

# Deployment package (generated by build-deploy.sh)
deploy/

# Disk images (large binary files)
disk-image/

# Environment specific
.env
config.local.php

# Admin password (external, not in git)
admin_password.php
